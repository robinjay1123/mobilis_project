flowchart LR
    subgraph Actors
        R[Renter]
        P[Partner]
        D[Driver]
        O[Operator]
        A[Admin]
    end

    subgraph Platform_Core
        I[Identity and Access]
        V[Verification and Trust]
        S[Supply Management]
        DM[Demand Management]
        DP[Dispatch and Fulfillment]
        T[Trip Execution]
        F[Financial Governance]
        X[Feedback and Ratings]
    end

    subgraph Outcomes
        SR[Service Reliability]
        C[Trust and Safety]
        E[Economic Value]
        Q[Experience Quality]
    end

    R --> I
    P --> I
    D --> I
    O --> I
    A --> I

    I --> V
    V --> S
    V --> DM
    S --> DP
    DM --> DP
    DP --> T
    T --> F
    T --> X
    
    T --> SR
    DP --> SR
    F --> E
    X --> Q
    V --> C

    O --> DP
    A --> V
    A --> C

    X -.->|learning loop| V
    X -.->|optimization loop| S
    F -.->|incentive loop| D
    F -.->|incentive loop| P
